@{
    ViewData["Title"] = "Resume";
}

<style>
    .resume-header {
        background-color: #0d1117;
        color: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    
    .section-heading {
        position: relative;
        padding-left: 1rem;
        margin-bottom: 1.5rem;
        font-weight: 700;
        color: #0d1117;
    }
    
    .section-heading::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background-color: #0d6efd;
        border-radius: 2px;
    }
    
    .timeline-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
        transition: transform 0.2s;
        background-color: white;
    }
    
    .timeline-card:hover {
        transform: translateX(5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }
    
    .skill-badge {
        font-size: 0.9rem;
        padding: 0.5rem 1rem;
        border-radius: 50rem;
        background-color: #f8f9fa;
        color: #0d1117;
        border: 1px solid #dee2e6;
        transition: all 0.2s;
    }
    
    .skill-badge:hover {
        background-color: #0d6efd;
        color: white;
        border-color: #0d6efd;
    }
</style>

<div class="container py-5">
    <!-- Header Banner -->
    <div class="resume-header p-5 mb-5 text-center text-md-start">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-bold mb-2">Micheal Dalu</h1>
                <p class="fs-4 text-primary mb-3">Backend Engineer</p>
                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-md-start text-light opacity-75">
                    <span><i class="bi bi-envelope-fill me-2"></i><a href="mailto:simdimike123@gmail.com" class="text-light text-decoration-none">simdimike123@gmail.com</a></span>
                    <span><i class="bi bi-telephone-fill me-2"></i>(555) 123-4567</span>
                    <span><i class="bi bi-geo-alt-fill me-2"></i>Nigeria</span>
                </div>
            </div>
            <div class="col-md-4 text-md-end mt-4 mt-md-0">
                <a href="#" class="btn btn-outline-light rounded-pill px-4 py-2">
                    <i class="bi bi-download me-2"></i>Download PDF
                </a>
            </div>
        </div>
    </div>

    <div class="row g-5">
