                <div class="card timeline-card mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="fw-bold mb-0">Intern Developer</h5>
                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">2022 – Present</span>
                        </div>
                        <p class="text-primary fw-semibold mb-3">Bincom Academy</p>
                        <ul class="text-secondary mb-0">
                            <li class="mb-2">Developing full-stack projects using ASP.NET Core, MVC architecture, and React for rich UIs.</li>
                            <li>Creating and deploying web applications to Microsoft Azure, managing app services and SQL databases.</li>
                        </ul>
                    </div>
                </div>

                <div class="card timeline-card mb-4">
                    <div class="card-body p-4">
