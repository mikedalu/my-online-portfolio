                            <h5 class="fw-bold mb-0">Web Developer</h5>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2 rounded-pill">2019 – 2022</span>
                        </div>
                        <p class="text-primary fw-semibold mb-3">Zinox Tech</p>
