@model IEnumerable<my_online_portfolio.Models.Gallery>

@{
    ViewData["Title"] = "Gallery";
}

<style>
    .gallery-header {
        background-color: #0d1117;
        color: white;
        padding: 4rem 0;
        margin-bottom: 3rem;
        border-radius: 0 0 2rem 2rem;
    }
    
    .gallery-item {
        position: relative;
        overflow: hidden;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background-color: white;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    
    .gallery-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.15);
    }
    
    .gallery-img-container {
        position: relative;
        width: 100%;
        padding-top: 100%; /* 1:1 Aspect Ratio */
        overflow: hidden;
    }
    
    .gallery-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    
    .gallery-item:hover .gallery-img {
        transform: scale(1.05);
    }
    
    .gallery-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(13, 17, 23, 0.8) 100%);
        opacity: 0;
        transition: opacity 0.3s ease;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1.5rem;
    }
    
    .gallery-item:hover .gallery-overlay {
        opacity: 1;
    }
    
    .delete-btn-overlay {
        position: absolute;
        top: 1rem;
        right: 1rem;
        opacity: 0;
        transition: opacity 0.3s ease, transform 0.2s;
    }
    
    .gallery-item:hover .delete-btn-overlay {
        opacity: 1;
    }
    
    .delete-btn-overlay:hover {
        transform: scale(1.1);
    }
</style>

<div class="gallery-header text-center">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3"><i class="bi bi-images me-3 text-primary"></i>Photo Gallery</h1>
        <p class="fs-5 text-white-50 max-w-50 mx-auto mb-4">
            A collection of my work, projects, and memorable moments.
        </p>
        <a href="/Gallery/Upload" class="btn btn-primary btn-lg rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-cloud-arrow-up-fill me-2"></i>Upload New Image
        </a>
    </div>
</div>

<div class="container pb-5 mb-5">
    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="gallery-item">
                        <div class="gallery-img-container">
                            <img src="@item.ImagePath" alt="@item.Title" class="gallery-img" />
                            
                            <div class="gallery-overlay text-white text-start">
                                <h5 class="fw-bold mb-1 text-truncate" title="@item.Title">@item.Title</h5>
                                <small class="text-white-50"><i class="bi bi-calendar3 me-1"></i>@item.UploadedAt.ToString("MMM dd, yyyy")</small>
                            </div>

                            <form method="post" action="/Gallery/Delete/@item.Id" onsubmit="return confirm('Delete this image?')" class="delete-btn-overlay">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm rounded-circle shadow" style="width: 35px; height: 35px; padding: 0; display: flex; align-items: center; justify-content: center;" title="Delete Image">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="py-5">
            <div class="h-100 d-flex flex-column align-items-center justify-content-center border border-dashed rounded-4 bg-light p-5 text-muted" style="min-height: 400px; border-width: 2px;">
                <i class="bi bi-images display-1 mb-4 text-secondary opacity-50"></i>
                <h3 class="fw-bold text-dark">No Images Found</h3>
                <p class="text-center fs-5 mb-4">Your gallery is currently empty. Start building your portfolio by uploading some images.</p>
                <a href="/Gallery/Upload" class="btn btn-primary btn-lg rounded-pill px-4 fw-bold shadow-sm">
                    <i class="bi bi-cloud-arrow-up-fill me-2"></i>Upload First Image
                </a>
            </div>
        </div>
    }
</div>
