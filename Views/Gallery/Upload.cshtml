@{
    ViewData["Title"] = "Upload Image";
}

<style>
    .upload-card {
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        border: none;
        overflow: hidden;
    }
    
    .upload-header {
        background: linear-gradient(135deg, #0d1117 0%, #161b22 100%);
        color: white;
        padding: 2rem;
        text-align: center;
    }
    
    .upload-zone {
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        background-color: #f8f9fa;
        padding: 3rem 2rem;
        text-align: center;
        transition: all 0.3s ease;
        position: relative;
    }
    
    .upload-zone:hover {
        border-color: #0d6efd;
        background-color: rgba(13, 110, 253, 0.02);
    }
    
    .upload-icon {
        font-size: 4rem;
        color: #adb5bd;
        margin-bottom: 1rem;
        transition: color 0.3s ease;
    }
    
    .upload-zone:hover .upload-icon {
        color: #0d6efd;
    }
    
    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }
    
    .file-input-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
        z-index: 10;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card upload-card mt-3 mb-5">
                <div class="upload-header">
                    <h3 class="fw-bold mb-0"><i class="bi bi-cloud-arrow-up text-primary me-2"></i>Upload Image</h3>
                    <p class="text-white-50 mb-0 mt-2 small">Add a new photo to your showcase gallery</p>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                            <div>@ViewBag.Error</div>
                        </div>
                    }

                    <form method="post" enctype="multipart/form-data">
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark mb-2">Image Title</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-fonts"></i></span>
                                <input type="text" name="title" class="form-control border-start-0 ps-0" placeholder="E.g., Project meeting, UI Design..." required />
                            </div>
                        </div>
                        
                        <div class="mb-5">
                            <label class="form-label fw-bold text-dark mb-2">Select Image File</label>
                            
                            <div class="upload-zone">
                                <i class="bi bi-image upload-icon"></i>
                                <h5 class="fw-bold text-dark">Click to browse or drag image here</h5>
                                <p class="text-muted small mb-0">Supports JPG, PNG, GIF</p>
                                
                                <input type="file" name="imageFile" class="file-input-overlay" accept="image/*" required 
                                       onchange="document.getElementById('fileNameDisplay').textContent = this.files[0] ? this.files[0].name : 'No file chosen';" />
                            </div>
                            <div class="mt-2 text-center text-primary small fw-semibold" id="fileNameDisplay"></div>
                        </div>
                        
                        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                            <button type="submit" class="btn btn-primary btn-lg px-4 fw-bold rounded-pill shadow-sm w-100">
                                <i class="bi bi-upload me-2"></i>Upload Now
                            </button>
                            <a href="/Gallery" class="btn btn-light border btn-lg px-4 fw-bold rounded-pill w-100">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>