<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Micheal Dalu</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/my_online_portfolio.styles.css" asp-append-version="true" />
    <style>
        .custom-navbar {
            background-color: #0d1117 !important;
        }
        .nav-link.custom-link {
            color: rgba(255, 255, 255, 0.7) !important;
            transition: color 0.3s ease, text-decoration 0.3s ease;
            position: relative;
        }
        .nav-link.custom-link:hover {
            color: #ffffff !important;
        }
        .nav-link.custom-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 50%;
            background-color: #0d6efd;
            transition: all 0.3s ease-in-out;
            transform: translateX(-50%);
        }
        .nav-link.custom-link:hover::after {
            width: 80%;
        }
        .nav-link.custom-link.active {
            color: #ffffff !important;
            font-weight: 600;
        }
        .nav-link.custom-link.active::after {
            width: 80%;
        }
        .custom-footer {
            background-color: #0d1117;
            color: rgba(255, 255, 255, 0.7);
        }
        .footer-link {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .footer-link:hover {
            color: #0d6efd;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm custom-navbar navbar-dark border-bottom border-secondary sticky-top mb-4 shadow-sm">
            <div class="container-fluid" style="max-width:1400px;">
                <a class="navbar-brand text-white fw-bold d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-code-square text-primary"></i> Micheal Dalu
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 justify-content-end gap-2">
                        <li class="nav-item">
                            <a class="nav-link custom-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "CvResume" ? "active" : "")" asp-area="" asp-controller="CvResume" asp-action="Index">Resume</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AboutMe" ? "active" : "")" asp-area="" asp-controller="AboutMe" asp-action="Index">About Me</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "CalculateTax" ? "active" : "")" asp-area="" asp-controller="CalculateTax" asp-action="Index">Tax Calculator</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Gallery" ? "active" : "")" asp-area="" asp-controller="Gallery" asp-action="Index">Gallery</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="flex-grow-1">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="custom-footer py-4 mt-auto border-top border-secondary">
        <div class="container border-secondary pt-3">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    <h5 class="text-white fw-bold mb-1"><i class="bi bi-code-square text-primary me-2"></i>Micheal Dalu</h5>
                    <small>Backend Engineer</small>
                </div>
                <div class="col-md-4 text-center mb-3 mb-md-0 d-flex justify-content-center gap-3">
                    <a href="/" class="footer-link"><i class="bi bi-house-door"></i> Home</a>
                    <a href="/CvResume" class="footer-link"><i class="bi bi-file-person"></i> Resume</a>
                    <a href="/AboutMe" class="footer-link"><i class="bi bi-person-badge"></i> About</a>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <small>&copy; 2026 - Micheal Dalu. All rights reserved.</small>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
